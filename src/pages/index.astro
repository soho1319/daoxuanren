---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section style="text-align:center; padding:3em 0 2em;">
				<h1 style="font-size:2.4em; margin:0 0 0.3em; font-weight:300; letter-spacing:0.15em;">道玄人</h1>
				<p style="color:rgb(var(--gray)); font-size:1.05em; margin:0;">一个让道玄人找到归宿的地方</p>
			</section>

			<hr style="margin:2em 0 3em;" />

			{posts.length > 0 ? (
				<section>
					<h2 style="font-size:1.1em; font-weight:400; color:rgb(var(--gray)); margin-bottom:1.5em; letter-spacing:0.05em;">近期文章</h2>
					<ul style="list-style:none; padding:0; margin:0;">
						{posts.map((post) => (
							<li style="margin-bottom:1.8em;">
								<a href={`/${post.slug}`} style="font-size:1.15em; border:none; color:rgb(var(--black));">{post.data.title}</a>
								{post.data.pubDate && (
									<div style="font-size:0.85em; color:rgb(var(--gray)); margin-top:0.3em;">
										<FormattedDate date={post.data.pubDate} />
									</div>
								)}
								{post.data.description && (
									<p style="margin:0.4em 0 0; color:rgb(var(--gray)); font-size:0.95em; line-height:1.6;">{post.data.description}</p>
								)}
							</li>
						))}
					</ul>
				</section>
			) : (
				<p style="color:rgb(var(--gray)); text-align:center; padding:3em 0;">暂无文章，道玄人正在路上……</p>
			)}
		</main>
		<Footer />
	</body>
</html>
